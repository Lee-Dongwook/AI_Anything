# Copy to .env and fill in. All vars are prefixed E2E_HEALER_ (see app/config.py).

# NVIDIA NIM (OpenAI-compatible Structured Outputs)
E2E_HEALER_NVIDIA_API_KEY=nvapi-...
E2E_HEALER_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
E2E_HEALER_NVIDIA_MODEL=openai/gpt-oss-120b
E2E_HEALER_NVIDIA_MAX_TOKENS=4096

# Repair loop
E2E_HEALER_MAX_LOOPS=3

# Playwright invocation used by the Test Runner node
E2E_HEALER_PLAYWRIGHT_CMD=npx playwright test

# Selector Verifier — check patched selectors against the live DOM before re-running.
# Verification is skipped (loop proceeds unverified) when APP_URL is empty or unreachable.
E2E_HEALER_VERIFY_SELECTORS=true
E2E_HEALER_APP_URL=
E2E_HEALER_NODE_CMD=node

# Sandbox — relaxed blocks dangerous paths; strict also enforces workspace/write globs.
E2E_HEALER_SANDBOX_MODE=relaxed
E2E_HEALER_WORKSPACE_ROOT=.
E2E_HEALER_WRITE_GLOBS=*.spec.js,*.spec.jsx,*.spec.ts,*.spec.tsx,*.test.js,*.test.jsx,*.test.ts,*.test.tsx,**/*.spec.js,**/*.spec.jsx,**/*.spec.ts,**/*.spec.tsx,**/*.test.js,**/*.test.jsx,**/*.test.ts,**/*.test.tsx
E2E_HEALER_DENY_GLOBS=.env,.env.*,**/.env,**/.env.*,.git/**,.github/**,node_modules/**,.venv/**,uv.lock,package-lock.json,pnpm-lock.yaml,yarn.lock
E2E_HEALER_ALLOW_TEMP_HELPER=true

# Logging
E2E_HEALER_LOG_LEVEL=INFO

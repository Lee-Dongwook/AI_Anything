# Copy to .env and fill in. All vars are prefixed E2E_HEALER_ (see app/config.py).

# OpenAI (Structured Outputs)
E2E_HEALER_OPENAI_API_KEY=sk-...
E2E_HEALER_OPENAI_MODEL=gpt-4o-2024-08-06

# Repair loop
E2E_HEALER_MAX_LOOPS=3

# Playwright invocation used by the Test Runner node
E2E_HEALER_PLAYWRIGHT_CMD=npx playwright test

# Logging
E2E_HEALER_LOG_LEVEL=INFO
